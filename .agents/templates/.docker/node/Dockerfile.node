FROM node:22-alpine AS base

LABEL maintainer="Ambiente node"
LABEL description="Ambiente de desenvolvimento Node.js"

WORKDIR /app

RUN npm install -g npm@latest --silent

FROM base AS dev

EXPOSE 5173 3000

CMD ["sh", "-c", "if [ -f package.json ]; then npm install && (npm run dev -- --host 0.0.0.0 || npm start); else tail -f /dev/null; fi"]

FROM base AS prod

COPY . .

RUN if [ -f package.json ]; then npm install --omit=dev; fi

EXPOSE 3000

CMD ["sh", "-c", "if npm run | grep -q ' start'; then npm start; else npx serve -s dist -l 3000; fi"]
