FROM python:3.12-slim AS base

LABEL maintainer="Ambiente python"
LABEL description="Ambiente de desenvolvimento Python"

WORKDIR /app

ENV PYTHONDONTWRITEBYTECODE=1
ENV PYTHONUNBUFFERED=1

RUN apt-get update \
    && apt-get install -y --no-install-recommends libpq5 curl \
    && rm -rf /var/lib/apt/lists/*

RUN pip install --no-cache-dir uv

FROM base AS dev

CMD ["sh", "-c", "if [ -f pyproject.toml ]; then uv sync || true; elif [ -f requirements.txt ]; then uv pip install --system -r requirements.txt; fi; tail -f /dev/null"]

FROM base AS prod

COPY . .

RUN if [ -f pyproject.toml ]; then uv sync --no-dev || true; elif [ -f requirements.txt ]; then uv pip install --system -r requirements.txt; fi

CMD ["python", "main.py"]
